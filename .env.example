# Listen address. Use :8081, :8090 etc. if :8080 is taken.
ADDR=:8080

# Proxy auth. If empty, /v1/chat/completions and /v1/responses are unauthenticated.
# When set, clients must pass Authorization: Bearer <PROXY_API_KEY> (or X-API-Key).
PROXY_API_KEY=

# How often to refresh each provider's model list, and per-request fetch timeout.
MODEL_REFRESH_INTERVAL=10m
MODEL_FETCH_TIMEOUT=30s

# ---------- Kilo ----------
KILO_ENABLED=true
KILO_MODELS_URL=https://api.kilo.ai/api/gateway/models
KILO_CHAT_URL=https://api.kilo.ai/api/gateway/v1/chat/completions
KILO_RESPONSES_URL=https://api.kilo.ai/api/gateway/v1/responses
# Forwarded as upstream Authorization header. Typically empty (Kilo's free models need no auth).
KILO_AUTHORIZATION=
# Substring matched against model id/name when isFree is not set on the upstream entry.
KILO_FREE_MATCH=free

# ---------- OpenCode ----------
OPENCODE_ENABLED=true
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_API_KEY=public
# When true, keep only models whose id ends in -free, strip the suffix for the public list,
# and re-append it when forwarding requests.
OPENCODE_IS_FREE=true
